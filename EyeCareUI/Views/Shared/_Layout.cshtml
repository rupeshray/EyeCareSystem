<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Eyecare</title>

    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="~/css/fonts.googleapis.com.css">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="~/css/plugins/fontawesome-free/css/all.min.css">
    <!-- overlayScrollbars -->
    <link rel="stylesheet" href="~/css/plugins/overlayScrollbars/css/OverlayScrollbars.min.css">
    <link rel="stylesheet" href="~/lib/toastr/toastr.min.css" />
    <!-- Theme style -->
    <link rel="stylesheet" href="~/css/adminlte.min.css">
    <link href="~/css/Custom.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/js/jquery-ui/jquery-ui.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap-switch/css/bootstrap3/bootstrap-switch.min.css" />
    <link rel="stylesheet" href="~/lib/bs-stepper/css/bs-stepper.min.css" />
    <link href="~/js/leaflet/leaflet.css" crossorigin="" rel="stylesheet" />
    <link href="~/css/jasny-bootstrap.min.css" crossorigin="" rel="stylesheet" />
    <!-- REQUIRED SCRIPTS -->
    <!-- jQuery -->
    <script src="~/js/jquery.min.js"></script>
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <script src="~/js/leaflet/leaflet.js" crossorigin=""></script>
    <script src="~/js/jasny-bootstrap.min.js"></script>
</head>
<body class="hold-transition layout-navbar-fixed layout-footer-fixed sidebar-collapse dark-mode">
    <div class="wrapper">
        <!-- Preloader -->
        @await Html.PartialAsync("~/Views/Shared/Menu/_Logo.cshtml")
        <!-- Navbar -->
        @await Html.PartialAsync("~/Views/Shared/Menu/_Navbar.cshtml")
        <!-- /.navbar -->
        <!-- Main Sidebar Container -->
        @await Html.PartialAsync("~/Views/Shared/Menu/_MainSidebar.cshtml")
        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Content Header (Page header) -->
            @await Html.PartialAsync("~/Views/Shared/Menu/_BreadCrumb.cshtml")
            <!-- /.content-header -->
            <!-- Main content -->
            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div><!--/. container-fluid -->
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <!-- Main Footer -->
        @await Html.PartialAsync("~/Views/Shared/Menu/_Footer.cshtml")
    </div>
    <!-- ./wrapper -->

    <script>
        $.widget.bridge('uibutton', $.ui.button)
    </script>
    <script src="~/lib/toastr/toastr.min.js"></script>
    <script src="~/lib/bootstrap-switch/js/bootstrap-switch.min.js"></script>

    <!-- Bootstrap -->
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <!-- overlayScrollbars -->
    <script src="~/lib/overlayScrollbars/jquery.overlayScrollbars.min.js"></script>

    <script src="~/lib/bs-stepper/js/bs-stepper.min.js"></script>
    <!-- AdminLTE App -->
    <script src="~/js/adminlte.js"></script>
    <script src="~/js/Custom/Pagination.js"></script>
    <script src="~/lib/Custom/CreateForm.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".BSswitch").bootstrapSwitch({
                onText: 'Yes',
                offText: 'No',
                size: 'small',
                onColor: 'success',
                offColor: 'danger'
            });
        });
    </script>
</body>
</html>
